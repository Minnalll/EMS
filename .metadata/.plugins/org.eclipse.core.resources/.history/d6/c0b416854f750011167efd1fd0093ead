package com.ems.employee.controller;

import java.util.List;

import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.http.ResponseEntity;
import org.springframework.web.bind.annotation.DeleteMapping;
import org.springframework.web.bind.annotation.GetMapping;
import org.springframework.web.bind.annotation.PathVariable;
import org.springframework.web.bind.annotation.PostMapping;
import org.springframework.web.bind.annotation.PutMapping;
import org.springframework.web.bind.annotation.RequestBody;
import org.springframework.web.bind.annotation.RequestMapping;
import org.springframework.web.bind.annotation.RestController;

import com.ems.employee.model.Employee;
import com.ems.employee.service.EmployeeService;

@RestController
@RequestMapping("/employee")
public class EmployeeController {
	
	@Autowired
	private EmployeeService serv;
	
	@PostMapping
	public Employee createEmployee(@RequestBody Employee empl) {
		Employee employee = serv.createEmployee(empl);	
		return serv.getEmployees(employee.getEmployee_id());
	}
	
	@GetMapping
	public List<Employee> getEmployees() {
		return serv.getEmployees();
	}
	
	@GetMapping("{eid}")
	public Employee getEmployees(@PathVariable Long eid) {
		return serv.getEmployees(eid);
	}
	
	@PutMapping("{eid}")
	public Employee updateEmployee(@PathVariable Long eid, @RequestBody Employee empl) {
		return serv.updateEmployee(eid, empl);		
	}
	
	@DeleteMapping("/{id}")
	public ResponseEntity<Void> deleteEmployee(@PathVariable Long id) {
	    serv.deleteEmployee(id);
	    return ResponseEntity.noContent().build();
	}

}
